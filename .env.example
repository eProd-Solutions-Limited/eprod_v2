# PostgreSQL — get this from Neon, Supabase, Railway, etc.
DATABASE_URL=postgresql://user:password@host/dbname

PAYLOAD_SECRET=YOUR_SECRET_HERE

# Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eprod.io

# Site URL (used for sitemap and robots.txt — no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.eprod-solutions.com

# Google Analytics 4
# Measurement ID — from GA4 console: Admin → Data Streams → Web stream → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# GA4 Data API (for the internal analytics dashboard)
# Property ID — from GA4 console: Admin → Property Settings → Property ID (numeric)
GOOGLE_GA_PROPERTY_ID=123456789
# Service account credentials JSON (stringified) — from Google Cloud Console → IAM → Service Accounts → Keys
# Share the GA4 property with the service account email as Viewer before use
GOOGLE_SA_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
