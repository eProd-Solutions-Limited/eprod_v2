# Turso (remote) — takes priority over DATABASE_URL when set
TURSO_DATABASE_URL=libsql://<db-name>-<org>.turso.io
TURSO_AUTH_TOKEN=

# Local SQLite fallback (dev only)
DATABASE_URL=file:./eprodv2.db

PAYLOAD_SECRET=YOUR_SECRET_HERE

# Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eprod.io
